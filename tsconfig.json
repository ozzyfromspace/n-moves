{
  // Nuxt 4 generates split TS configs under .nuxt/ (via `nuxt prepare`).
  // This root config just references them; do not add settings here —
  // put overrides in nuxt.config `typescript.tsConfig` instead.
  "files": [],
  "references": [
    { "path": "./.nuxt/tsconfig.app.json" },
    { "path": "./.nuxt/tsconfig.server.json" },
    { "path": "./.nuxt/tsconfig.shared.json" },
    { "path": "./.nuxt/tsconfig.node.json" }
  ]
}
